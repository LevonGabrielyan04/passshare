# Copy to .env before running: cp .env.docker.example .env
# Then set secrets (APP_KEY, DB passwords, PASSKEYS_USER_HANDLE_SECRET, optional Flux license).
#
# Use docker/bin/compose.sh (or export COMPOSE_ENV_FILES=.env.compose) so Compose reads
# .env.compose for port mapping only. Application secrets stay in .env and are passed
# literally via env_file — passwords may contain $ and other special characters.

APP_NAME=DropKey
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dropkey.site
APP_PORT=8080

LOG_LEVEL=info

DB_DATABASE=passshare
DB_USERNAME=passshare
DB_PASSWORD=change-me-app-db-password

MARIADB_ROOT_PASSWORD=change-me-root-db-password
MARIADB_DATABASE=passshare
MARIADB_USER=passshare
MARIADB_PASSWORD=change-me-app-db-password

BCRYPT_ROUNDS=12
HASH_DRIVER=argon2id
ARGON_MEMORY=131072
ARGON_THREADS=4

SESSION_DRIVER=redis
SESSION_LIFETIME=5
SESSION_ENCRYPT=true
SESSION_EXPIRE_ON_CLOSE=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_PATH=/
SESSION_DOMAIN=null

REDIS_PASSWORD=change-me-redis-password

MAIL_MAILER=resend
MAIL_FROM_ADDRESS=hello@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

PASSKEYS_USER_HANDLE_SECRET=

# Pre-built image from GitHub Actions (docker/bin/deploy.sh). Lowercase owner required.
APP_IMAGE=ghcr.io/levongabrielyan04/passshare:latest

# GitHub account that owns the PAT (for docker login ghcr.io). Lowercase username.
GHCR_USERNAME=levongabrielyan04

# GitHub PAT with read:packages — lets the server pull private images from GHCR.
GHCR_TOKEN=

# Optional: passed as Docker build secrets when building the image (Livewire Flux license).
FLUX_USERNAME=
FLUX_LICENSE_KEY=

# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → your tunnel → Install connector).
# Required for production: ./docker/bin/compose.sh up --tunnel
TUNNEL_TOKEN=

# nginx is the only upstream proxy; cloudflared reaches it on the isolated tunnel network.
# In Cloudflare Zero Trust, set the tunnel origin to http://172.30.200.2:8080 (not app:8080).
TRUSTED_PROXIES=127.0.0.1

SEND_CACHE_TTL=60
MAX_MESSAGE_LENGTH=1000
ENCRYPTED_MAX_MESSAGE_LENGTH=5372
MAX_SENDS_PER_USER=15

POLICY_DENIAL_LOGGING_ENABLED=true
POLICY_DENIAL_LOG_MAX_PER_MINUTE=10
POLICY_DENIAL_LOG_GLOBAL_MAX_PER_MINUTE=100
POLICY_DENIAL_LOG_THROTTLE_BY=ip

# Laravel Pulse — dashboard at /pulse; pulse:check runs in the app container via Supervisor.
# Define the viewPulse gate in AppServiceProvider for production access.
PULSE_ENABLED=true
PULSE_ADMIN_EMAIL=levongabrielyan44@gmail.com
PULSE_CACHE_DRIVER=redis
PULSE_USER_REQUESTS_ENABLED=true
PULSE_USER_JOBS_ENABLED=true

RESEND_API_KEY=

# Cloudflare Turnstile — required for registration, login, and password reset in production.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
